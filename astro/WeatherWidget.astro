---
type Props = {
	city: string;
	scale?: "C" | "F";
	iconStyle?: "filled" | "outline" | "sharp";
	apiKey: string;
};

const {
	city,
	scale = "C",
	iconStyle = "filled",
	apiKey,
} = Astro.props as Props;

// @ts-expect-error Vite resolves `?raw` imports for browser assets at build time.
import widgetScript from "../dist/weather-widget.js?raw";
---

<weather-widget
	city={city}
	scale={scale}
	icon-style={iconStyle}
	api-key={apiKey}
></weather-widget>

<!-- Inline the built browser module to avoid server MIME-type issues. -->
<script
	type="module"
	is:inline
	set:html={widgetScript}
></script>
